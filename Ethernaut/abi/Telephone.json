	"source": "// SPDX-License-Identifier: MIT\r\npragma solidity 0.8.19;\r\n\r\ncontract Telephone {\r\n    address public owner;\r\n\r\n    constructor() {\r\n        owner = msg.sender;\r\n    }\r\n\r\n    function changeOwner(address _owner) public {\r\n        if (tx.origin != msg.sender) {\r\n            owner = _owner;\r\n        }\r\n    }\r\n}\r\n",
